# Twitter credentials
TWITTER_USERNAME=your_username
TWITTER_PASSWORD=your_password

# Feishu webhook (optional)
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook-id

# Browser CDP port
CDP_PORT=18800

# Database path
DB_PATH=data/tweets.db

# Crawl settings
CRAWL_LIMIT=50
