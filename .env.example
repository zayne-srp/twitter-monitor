# Prerequisites: openclaw browser must be running with CDP on port 18800 and already logged in to Twitter

# Feishu webhook (optional)
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook-id

# Browser CDP port
CDP_PORT=18800

# Database path
DB_PATH=data/tweets.db

# Crawl settings
CRAWL_LIMIT=50

# OpenAI API key (optional, for AI-powered tweet filtering)
OPENAI_API_KEY=your_openai_api_key
